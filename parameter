class Box {
private:
    int l, b, h;

public:
    // 1. Default Constructor
    Box() {
        l = 0;
        b = 0;
        h = 0;
    }

    // 2. Parameterized Constructor
    Box(int length, int breadth, int height) {
        l = length;
        b = breadth;
        h = height;
    }

    // 3. Copy Constructor (Must pass by reference to avoid infinite recursion)
    Box(const Box& B) {
        l = B.l;
        b = B.b;
        h = B.h;
    }

    // 4. Getter Functions
    int getLength() {
        return l;
    }

    int getBreadth() {
        return b;
    }

    int getHeight() {
        return h;
    }

    // 5. Volume Calculation (Cast to long long to prevent integer overflow)
    long long CalculateVolume() {
        return (long long)l * b * h;
    }

    // 6. Overloading < Operator
    bool operator<(const Box& B) {
        if (l < B.l) {
            return true;
        }
        if (b < B.b && l == B.l) {
            return true;
        }
        if (h < B.h && b == B.b && l == B.l) {
            return true;
        }
        return false;
    }

    // 7. Overloading << Operator (Friend function to access private members)
    friend ostream& operator<<(ostream& out, const Box& B) {
        out << B.l << " " << B.b << " " << B.h;
        return out;
    }
};
